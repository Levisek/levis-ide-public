# ── LevisIDE release upload credentials ──────────────
#
# Zkopíruj tento soubor jako .env.release (NE commitnutý — je v .gitignore)
# a doplň skutečné hodnoty. Používá se ve scripts/upload-release.mjs.
#
# WEDOS hosting — příklad hodnot:
#   WEDOS_FTP_HOST=255473.w73.wedos.net
#   WEDOS_FTP_USER=w255473
#   WEDOS_FTP_PASS=***your-password-here***
#   WEDOS_FTP_SECURE=true

WEDOS_FTP_HOST=
WEDOS_FTP_USER=
WEDOS_FTP_PASS=
WEDOS_FTP_SECURE=true
